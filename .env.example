# Finance Academy — Environment Variables
# Copy this file to .env and fill in your values.
# All PUBLIC_ variables are safe to expose in the browser.

# Supabase project URL (found in Project Settings → API)
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anonymous/public key (found in Project Settings → API)
PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role key — SERVER ONLY, never expose in the browser
# Used in API routes that need to bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# The canonical URL of your deployed site (no trailing slash)
# Used for auth redirect URLs
PUBLIC_SITE_URL=https://finance-academy-chi.vercel.app
